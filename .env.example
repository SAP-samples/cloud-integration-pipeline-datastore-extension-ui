
# ============================================================================
# 
#  LOCAL DEVELOPMENT:
#    - Copy this file / create a .env file in the project root with your values
#    - Run: npm install  (to install dotenv if needed)
#    - The application will load these variables on startup
#
# ============================================================================

# OAuth Token Endpoint
# The URL where the application can request OAuth access tokens
OAUTH_TOKEN_URL=https://your-auth-endpoint/oauth/token

# OAuth Client ID 
OAUTH_CLIENT_ID=your-client-id

# OAuth Client Secret
OAUTH_CLIENT_SECRET=your-client-secret

# Data Store Retry API Base URL - The root URL of your Data Store Retry API (without trailing slash)
API_BASE_URL=https://your-api-endpoint/http/pipeline/api/v1

# ============================================================================

